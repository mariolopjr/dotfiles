# ghostty +show-config --default --docs
# ghostty +show-config --default | grep {option-name}
# ghostty +list-themes
# ghostty +list-fonts

# Font
#
## Font features
# calt: variable width / texture healing
# ss01: equals ligatures: ==
# ss02: less/greater than ligatures: <=
# ss03: arrow ligatures: ->
# ss04: markup ligatures: </
# ss05: F# ligatures: |>
# ss06: repeating character ligatures: ###
# ss07: colon ligatures: ::
# ss08: period ligatures: ..=
# ss09: less/greater than ligatures with other characters: =<<
# ss10: other tag ligatures: #[
# liga: dynamic spacing for repeating char patterns
font-family                    = Monaspace Neon
font-feature                   = calt,liga,ss01,ss03,ss04,ss05,ss06,ss07,ss08,ss09,ss10
font-thicken                   = true
font-size                      = 14

# Look and Feel
adjust-cursor-thickness        = 10
adjust-underline-position      = 3
bold-is-bright                 = true
mouse-hide-while-typing        = true
theme                          = Catppuccin Macchiato
window-save-state              = always

# Other
command                        = /opt/homebrew/bin/fish -l
copy-on-select                 = true
auto-update                    = off

# Key bindings
## splits
keybind                        = ctrl+h=goto_split:left
keybind                        = ctrl+j=goto_split:bottom
keybind                        = ctrl+k=goto_split:top
keybind                        = ctrl+l=goto_split:right
keybind                        = ctrl+shift+h=new_split:left
keybind                        = ctrl+shift+j=new_split:down
keybind                        = ctrl+shift+k=new_split:up
keybind                        = ctrl+shift+l=new_split:right
keybind                        = ctrl+alt+h=resize_split:left,30
keybind                        = ctrl+alt+j=resize_split:down,30
keybind                        = ctrl+alt+k=resize_split:up,30
keybind                        = ctrl+alt+l=resize_split:right,30

## other
keybind                        = super+r=reload_config
keybind                        = super+alt+enter=new_split:auto
keybind                        = global:ctrl+`=toggle_quick_terminal
