{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# Install brew taps and packages
# Package list lives in .chezmoidata/packages.toml

# Trust non-official taps before bundling
{{ range .packages.darwin.taps -}}
brew trust "{{ . }}"
{{ end }}
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.taps -}}
tap "{{ . }}"
{{ end -}}
{{ range .packages.darwin.brews -}}
{{ if kindIs "string" . -}}
brew "{{ . }}"
{{ else -}}
brew "{{ .name }}"{{ with .args }}, args: [{{ range $i, $a := . }}{{ if $i }}, {{ end }}"{{ $a }}"{{ end }}]{{ end }}
{{ end -}}
{{ end -}}
EOF
{{ end -}}
