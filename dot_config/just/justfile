# Global justfile
# run `just` to list recipes, `just <recipe>` to run one

# list available recipes
default:
  @just --global-justfile --list

# install or update the roslyn language server
roslyn-ls:
  dotnet tool update -g roslyn-language-server --prerelease --source https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-impl/nuget/v3/index.json

# install or update netcoredbg (the .NET debug adapter)
netcoredbg:
  #!/usr/bin/env bash
  set -euo pipefail
  url="https://github.com/Samsung/netcoredbg/releases/latest/download/netcoredbg-osx-arm64.zip"
  tmp="$(mktemp -d)"
  curl -sSL "$url" -o "$tmp/netcoredbg.zip"
  rm -rf ~/.netcoredbg
  unzip -q "$tmp/netcoredbg.zip" -d ~/.netcoredbg -x "__MACOSX/*"
  xattr -dr com.apple.quarantine ~/.netcoredbg
  rm -rf "$tmp"
  ~/.netcoredbg/netcoredbg/netcoredbg --version
