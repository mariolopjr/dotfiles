{{- if eq .chezmoi.os "darwin" }}
# refresh with `chezmoi apply -R` when a new netcoredbg is released

[".hammerspoon/Spoons/EmmyLua.spoon"]
type = "archive"
url = "https://github.com/Hammerspoon/Spoons/raw/master/Spoons/EmmyLua.spoon.zip"
stripComponents = 1

# netcoredbg, the .NET debug adapter used by nvim-dap for Godot, dap.lua loads
# it from ~/.netcoredbg/netcoredbg/netcoredbg
[".netcoredbg"]
type = "archive"
url = "https://github.com/Samsung/netcoredbg/releases/latest/download/netcoredbg-osx-{{ .chezmoi.arch }}.zip"
exclude = ["__MACOSX/**"]

# codelldb, the Rust debug adapter used by rustaceanvim
[".local/share/codelldb"]
type = "archive"
format = "zip"
url = "https://github.com/vadimcn/codelldb/releases/latest/download/codelldb-darwin-{{ if eq .chezmoi.arch "arm64" }}arm64{{ else }}x64{{ end }}.vsix"
stripComponents = 1
refreshPeriod = "8760h"

# smart-splits wezterm plugin
[".config/wezterm/plugins/smart-splits.lua"]
type = "file"
url = "https://raw.githubusercontent.com/mrjones2014/smart-splits.nvim/ba2850ff3d3b09785a7105c69d06a12117d4b97d/plugin/init.lua"
refreshPeriod = "8760h"
{{- end }}

# Renoise Lua API defs (LuaCATS) for lua_ls
[".local/share/luals/renoise-definitions"]
type = "archive"
url = "https://github.com/renoise/definitions/archive/refs/heads/master.tar.gz"
exact = true
stripComponents = 1
refreshPeriod = "8760h"

# pattrns phrase-script type stubs (types/pattrns subtree only)
[".local/share/luals/pattrns-types"]
type = "archive"
url = "https://github.com/renoise/pattrns/archive/refs/heads/master.tar.gz"
exact = true
stripComponents = 1
include = ["*/types/**", "types/**"]
refreshPeriod = "8760h"
